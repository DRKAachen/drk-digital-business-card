# PostgreSQL connection string (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/visitenkarte

# Auth.js secret – generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
# Required when running behind a reverse proxy (Coolify/Traefik/nginx)
AUTH_TRUST_HOST=true

# Authentik OIDC provider
AUTH_AUTHENTIK_ID=your-authentik-client-id
AUTH_AUTHENTIK_SECRET=your-authentik-client-secret
AUTH_AUTHENTIK_ISSUER=https://auth.your-domain.de/application/o/visitenkarte/

# S3-compatible storage (Hetzner Object Storage)
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_ACCESS_KEY=your-hetzner-access-key
S3_SECRET_KEY=your-hetzner-secret-key
S3_BUCKET=drk-visitenkarte
# Public base URL for serving photos (bucket must have a public-read policy).
# Virtual-hosted style: https://<bucket>.fsn1.your-objectstorage.com
NEXT_PUBLIC_S3_PUBLIC_URL=https://drk-visitenkarte.fsn1.your-objectstorage.com

# Site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ORG_NAME=DRK Digitale Visitenkarte
