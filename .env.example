# Supabase (required) - create a project at https://supabase.com (select EU region for GDPR)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase secret key (server-side only, NEVER expose to client)
# Required for admin operations like account deletion (DSGVO Art. 17)
# Preferred over legacy service_role JWT: independent rotation, browser-safe, no JWT expiry issues
# Find it in: Supabase Dashboard > Settings > API Keys > Create new API Keys > Secret key
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# Site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ORG_NAME=DRK Kreisverband Aachen e.V.
