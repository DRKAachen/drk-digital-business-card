# PostgreSQL connection string (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/visitenkarte

# Auth.js secret – generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Authentik OIDC provider
AUTH_AUTHENTIK_ID=your-authentik-client-id
AUTH_AUTHENTIK_SECRET=your-authentik-client-secret
AUTH_AUTHENTIK_ISSUER=https://auth.your-domain.de/application/o/visitenkarte/

# S3-compatible storage (Garage)
S3_ENDPOINT=https://garage.your-domain.de
S3_ACCESS_KEY=your-garage-access-key
S3_SECRET_KEY=your-garage-secret-key
S3_BUCKET=photos
NEXT_PUBLIC_S3_PUBLIC_URL=https://garage.your-domain.de/photos

# Site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ORG_NAME=DRK Digitale Visitenkarte
